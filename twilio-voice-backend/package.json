{
  "name": "twilio-voice-backend",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon --exec \"node --import ../scripts/workspace-module-loader.mjs\" server.js",
    "start": "node --import ../scripts/workspace-module-loader.mjs server.js",
    "validate:env": "node --import ../scripts/workspace-module-loader.mjs scripts/validate-env.mjs",
    "lint": "node ../scripts/check-js-syntax.mjs server.js src tests",
    "build": "npm run validate:env && npm run lint",
    "test": "node --import ../scripts/workspace-module-loader.mjs --test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@aihq/shared-contracts": "1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "twilio": "^5.4.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}

# Deprecated workspace example.
# Use the canonical root .env.example and copy only the values you need into
# a gitignored ai-hq-backend/.env.local file.

APP_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:5173
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/aihq_dev
WS_AUTH_TOKEN=REPLACE_WITH_WS_AUTH_TOKEN_IF_USED
AIHQ_INTERNAL_TOKEN=REPLACE_WITH_LONG_RANDOM_INTERNAL_TOKEN
USER_SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_USER_SESSION_SECRET
ADMIN_PANEL_ENABLED=0
PUSH_ENABLED=0
MEDIA_JOB_WORKER_ENABLED=0
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY_IF_USED
OPENAI_MODEL=gpt-5

# Website extraction runtime defaults now assume the stronger crawl budget from
# src/config.js. Only set SOURCE_SYNC_WEBSITE_* here if you intentionally want
# a different production/runtime limit.

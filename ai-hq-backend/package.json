{
  "name": "ai-hq-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "migrate": "node scripts/migrate.js",
    "validate:env": "node scripts/validate-env.mjs",
    "lint": "node ../scripts/check-js-syntax.mjs server.js src tests scripts",
    "build": "npm run validate:env && npm run lint",
    "test": "node --test --test-isolation=none tests/*.test.js",
    "test:setup-review": "node --test --test-isolation=none tests/setup-review-session.test.js"
  },
  "dependencies": {
    "@aihq/shared-contracts": "1.0.0",
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "openai": "^6.25.0",
    "pg": "^8.12.0",
    "playwright": "^1.58.2",
    "web-push": "^3.6.7",
    "ws": "^8.17.0"
  }
}

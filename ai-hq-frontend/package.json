{
  "name": "ai-hq-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "start": "vite",
    "dev:host": "vite --host",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:contracts && npm run test:smoke",
    "test:contracts": "node --test --test-isolation=none src/api/truth.test.js src/lib/appEntry.test.js src/pages/Settings/hooks/useSourceIntelligence.test.js src/pages/SetupStudio/hooks/setupStudioActionShared.test.js src/pages/SetupStudio/state/shared.test.js",
    "test:smoke": "vitest run --pool threads --maxWorkers 1 src/App.smoke.test.jsx src/pages/Executions.smoke.test.jsx src/pages/SetupStudio/SetupStudioScene.smoke.test.jsx src/pages/Truth/TruthViewerPage.smoke.test.jsx src/pages/Settings/SettingsController.smoke.test.jsx",
    "test:browser:smoke": "playwright test",
    "lint": "eslint .",
    "clean": "rimraf dist node_modules/.vite"
  },
  "dependencies": {
    "@aihq/shared-contracts": "file:../shared-contracts",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "@tanstack/react-table": "^8.21.3",
    "@tsparticles/react": "^3.0.0",
    "@tsparticles/slim": "^3.9.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.575.0",
    "maath": "^0.10.8",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-loading-skeleton": "^3.5.0",
    "react-router-dom": "^7.13.1",
    "reactflow": "^11.11.4",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.6",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.4",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }

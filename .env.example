# Canonical local environment inventory for the ProjectAIHQ monorepo.
# Copy only the values you need into gitignored .env.local files.
# Never commit real secrets, tokens, hashes, or private keys.

# Core app/runtime
APP_ENV=development
NODE_ENV=development
PORT=8080
PUBLIC_BASE_URL=http://localhost:8080
CORS_ORIGIN=http://localhost:5173
VITE_API_BASE=http://localhost:8080
VITE_WS_URL=ws://localhost:8080
VITE_ENABLE_INTERNAL_ROUTES=0
VITE_ENABLE_SERVICE_WORKER=0
VITE_DEBUG_PUSH=0
VITE_VAPID_PUBLIC_KEY=REPLACE_WITH_BASE64URL_PUBLIC_KEY_IF_PUSH_IS_ENABLED
AIHQ_PROCESS_ROLE=all

# Database
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/aihq_dev
DB_AUTO_MIGRATE_ON_STARTUP=0
DB_MIGRATE_TX=1
DB_SCHEMA_DEMO=false

# Sessions and internal trust
ADMIN_PANEL_ENABLED=0
ADMIN_PANEL_PASSCODE_HASH=REPLACE_WITH_HASH_IF_ADMIN_PANEL_IS_ENABLED
ADMIN_SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_ADMIN_SESSION_SECRET
USER_SESSION_SECRET=REPLACE_WITH_LONG_RANDOM_USER_SESSION_SECRET
AIHQ_INTERNAL_TOKEN=REPLACE_WITH_LONG_RANDOM_INTERNAL_TOKEN
AIHQ_INTERNAL_TOKEN_META_BOT=
AIHQ_INTERNAL_TOKEN_TWILIO_VOICE=
TENANT_SECRET_MASTER_KEY=REPLACE_WITH_LONG_RANDOM_MASTER_KEY
DEBUG_API_TOKEN=REPLACE_WITH_DEBUG_TOKEN_IF_DEBUG_ROUTES_ARE_ENABLED
DEBUG_ROUTES_ENABLED=0
CRON_SECRET=REPLACE_WITH_CRON_SECRET

# Cookies and tenant defaults
DEFAULT_TENANT_KEY=default
DEFAULT_TIMEZONE=Asia/Baku
SESSION_COOKIE_DOMAIN=
COOKIE_DOMAIN=
USER_COOKIE_DOMAIN=

# Push
PUSH_ENABLED=0
VAPID_PUBLIC_KEY=REPLACE_WITH_BASE64URL_PUBLIC_KEY_IF_PUSH_IS_ENABLED
VAPID_PRIVATE_KEY=REPLACE_WITH_BASE64URL_PRIVATE_KEY_IF_PUSH_IS_ENABLED
VAPID_SUBJECT=mailto:ops@example.test

# AI providers
OPENAI_API_KEY=REPLACE_WITH_OPENAI_KEY_IF_USED
OPENAI_MODEL=gpt-5
OPENAI_MAX_OUTPUT_TOKENS=1024
GEMINI_API_KEY=REPLACE_WITH_GEMINI_KEY_IF_USED
ANTHROPIC_API_KEY=REPLACE_WITH_ANTHROPIC_KEY_IF_USED

# Media providers and workers
MEDIA_JOB_WORKER_ENABLED=0
RUNWAY_API_KEY=REPLACE_WITH_RUNWAY_KEY_IF_USED
PIKA_API_KEY=REPLACE_WITH_PIKA_KEY_IF_USED
ELEVENLABS_API_KEY=REPLACE_WITH_ELEVENLABS_KEY_IF_USED
ELEVENLABS_VOICE_ID=REPLACE_WITH_ELEVENLABS_VOICE_ID_IF_USED
CREATOMATE_API_KEY=REPLACE_WITH_CREATOMATE_KEY_IF_USED
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=
TOGETHER_API_KEY=REPLACE_WITH_TOGETHER_KEY_IF_USED

# Meta/provider access
VERIFY_TOKEN=REPLACE_WITH_META_VERIFY_TOKEN_IF_META_BOT_IS_USED
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_PAGE_ACCESS_TOKEN=
META_GATEWAY_BASE_URL=
META_GATEWAY_INTERNAL_TOKEN=

# Google/provider access
GOOGLE_PLACES_API_KEY=REPLACE_WITH_GOOGLE_PLACES_KEY_IF_USED
GOOGLE_BUSINESS_PROFILE_CLIENT_ID=
GOOGLE_BUSINESS_PROFILE_CLIENT_SECRET=
GOOGLE_BUSINESS_PROFILE_REDIRECT_URI=

# n8n and automation
N8N_WEBHOOK_BASE=
N8N_WEBHOOK_URL=
N8N_WEBHOOK_PROPOSAL_APPROVED_URL=
N8N_WEBHOOK_PUBLISH_URL=
N8N_WEBHOOK_TOKEN=
N8N_CALLBACK_TOKEN=
# Older notes may call this N8N_SCHEDULE_DRAFT_URL. The repo reads
# N8N_WEBHOOK_SCHEDULE_DRAFT_URL.
N8N_WEBHOOK_SCHEDULE_DRAFT_URL=

# Notifications/integrations
CONTACT_EMAIL=ops@example.test
TELEGRAM_ENABLED=0
TELEGRAM_API_BASE_URL=https://api.telegram.org
TELEGRAM_WEBHOOK_BASE_URL=http://localhost:8080
TELEGRAM_CONNECT_TIMEOUT_MS=15000
TELEGRAM_STATUS_TIMEOUT_MS=10000
TELEGRAM_SEND_TIMEOUT_MS=15000
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEETS_WEBHOOK_TOKEN=

# Twilio voice sidecar
AIHQ_BASE_URL=http://localhost:8080
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID_IF_VOICE_IS_USED
TWILIO_API_KEY=REPLACE_WITH_TWILIO_API_KEY_IF_VOICE_IS_USED
TWILIO_API_SECRET=REPLACE_WITH_TWILIO_API_SECRET_IF_VOICE_IS_USED
TWILIO_TWIML_APP_SID=REPLACE_WITH_TWILIO_TWIML_APP_SID_IF_VOICE_IS_USED
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN_IF_VOICE_IS_USED
TWILIO_CALLER_ID=REPLACE_WITH_TWILIO_CALLER_ID_IF_VOICE_IS_USED
ALLOW_UNSAFE_TENANT_KEY_RESOLUTION=0
ALLOW_LOCAL_TENANT_CONFIG_FALLBACK=0

# Optional local development flags
SOURCE_SYNC_WORKER_ENABLED=1
DRAFT_SCHEDULE_WORKER_ENABLED=0
DURABLE_EXECUTION_WORKER_ENABLED=1
OUTBOUND_RETRY_ENABLED=1
REQUIRE_OPERATIONAL_READINESS_ON_BOOT=0
ENFORCE_OPERATIONAL_READINESS_ON_STARTUP=0

# Optional website extraction tuning.
# These are the current stronger runtime defaults; omit them unless you need overrides.
# SOURCE_SYNC_WEBSITE_FETCH_TIMEOUT_MS=7000
# SOURCE_SYNC_WEBSITE_PAGE_TIMEOUT_MS=7000
# SOURCE_SYNC_WEBSITE_ENTRY_TIMEOUT_MS=18000
# SOURCE_SYNC_WEBSITE_EXTRACT_TIMEOUT_MS=32000
# SOURCE_SYNC_WEBSITE_SYNC_TIMEOUT_MS=52000
# SOURCE_SYNC_WEBSITE_ROBOTS_TIMEOUT_MS=2200
# SOURCE_SYNC_WEBSITE_SITEMAP_TIMEOUT_MS=4500
# SOURCE_SYNC_WEBSITE_FINALIZE_RESERVE_MS=4000
# SOURCE_SYNC_WEBSITE_MIN_STEP_BUDGET_MS=400
# SOURCE_SYNC_WEBSITE_MAX_PAGES_ALLOWED=6
# SOURCE_SYNC_WEBSITE_MAX_CANDIDATES_QUEUED=40
# SOURCE_SYNC_WEBSITE_MAX_FETCH_PAGES=10
